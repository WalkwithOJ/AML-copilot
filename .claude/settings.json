{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "& \".claude\\hooks\\log-commands.ps1\"",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "& \".claude\\hooks\\auto-format.ps1\"",
            "shell": "powershell",
            "statusMessage": "Formatting Python file..."
          }
        ]
      }
    ]
  }
}
